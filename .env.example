# App Info
NODE_ENV=development
PORT=3000

# Next.js Public Vars
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase Service Role Key (for backend verification/actions)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Database Connection (Backend)
DATABASE_URL=postgresql://postgres:password@localhost:5432/healthcare

# Redis Connection (Backend / Celery)
REDIS_URL=redis://localhost:6379/0

# LiveKit (Video Consultation)
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_URL=http://localhost:7880

# Resend (Email service)
RESEND_API_KEY=re_your_resend_key

# Twilio (SMS/Notifications)
TWILIO_ACCOUNT_SID=ACyouraccount
TWILIO_AUTH_TOKEN=yourtoken
TWILIO_PHONE_NUMBER=+1234567890

# AI/LLM API Keys
GEMINI_API_KEY=your_gemini_key
GROQ_API_KEY=your_groq_key

# Monitoring
SENTRY_DSN=your_sentry_dsn
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
